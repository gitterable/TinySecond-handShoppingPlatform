<%- include('partials/header') %>

<div class="card">
  <h2>상품 등록</h2>
  <form action="/products" method="post" enctype="multipart/form-data">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <label>상품명
      <input type="text" name="name" value="<%= (values && values.name) || '' %>" required maxlength="100" />
    </label>
    <label>가격 (원)
      <input type="number" name="price" value="<%= (values && values.price) || '' %>" required min="0" step="1" />
    </label>
    <label>상품 설명
      <textarea name="description" rows="5" maxlength="2000"><%= (values && values.description) || '' %></textarea>
    </label>
    <label>상품 사진 (jpg/png/gif/webp, 최대 2MB)
      <input type="file" name="image" accept="image/*" />
    </label>
    <button type="submit" class="btn">등록하기</button>
  </form>
</div>

<%- include('partials/footer') %>
