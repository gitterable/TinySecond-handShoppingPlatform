<%- include('partials/header') %>

<h2>관리자 대시보드</h2>

<nav class="admin-tabs">
  <a href="#users">사용자</a>
  <a href="#products">상품</a>
  <a href="#reports">신고</a>
  <a href="#inquiries">문의</a>
  <a href="#transfers">송금내역</a>
  <a href="#chat">전체채팅</a>
</nav>

<div id="users"></div>

<div class="card">
  <h3>사용자 (<%= users.length %>)</h3>
  <table class="table">
    <thead><tr><th>ID</th><th>아이디</th><th>잔액</th><th>권한</th><th>상태</th><th>관리</th></tr></thead>
    <tbody>
      <% users.forEach(function(u) { %>
        <tr>
          <td><%= u.id %></td>
          <td><%= u.username %></td>
          <td><%= u.balance.toLocaleString() %></td>
          <td><%= u.is_admin ? '관리자' : '일반' %></td>
          <td><span class="badge badge-<%= u.status === 'active' ? 'ok' : 'danger' %>"><%= u.status %></span></td>
          <td class="row-actions">
            <% if (!u.is_admin) { %>
              <form action="/admin/users/<%= u.id %>/status" method="post" class="inline-form">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <input type="hidden" name="status" value="<%= u.status === 'active' ? 'suspended' : 'active' %>" />
                <button type="submit" class="link-btn"><%= u.status === 'active' ? '정지' : '해제' %></button>
              </form>
            <% } %>
            <form action="/admin/users/<%= u.id %>/charge" method="post" class="inline-form charge-form">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <input type="number" name="amount" min="1" step="1" placeholder="금액" required />
              <button type="submit" class="link-btn">충전</button>
            </form>
          </td>
        </tr>
      <% }); %>
    </tbody>
  </table>
</div>

<div id="products"></div>
<div class="card">
  <h3>상품 (<%= products.length %>)</h3>
  <table class="table">
    <thead><tr><th>ID</th><th>상품명</th><th>가격</th><th>판매자</th><th>상태</th><th>관리</th></tr></thead>
    <tbody>
      <% products.forEach(function(p) { %>
        <tr>
          <td><%= p.id %></td>
          <td><a href="/products/<%= p.id %>"><%= p.name %></a></td>
          <td><%= p.price.toLocaleString() %></td>
          <td><%= p.seller %></td>
          <td><span class="badge badge-<%= p.status === 'active' ? 'ok' : 'danger' %>"><%= p.status %></span></td>
          <td class="row-actions">
            <form action="/admin/products/<%= p.id %>/status" method="post" class="inline-form">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <input type="hidden" name="action" value="<%= p.status === 'active' ? 'block' : 'unblock' %>" />
              <button type="submit" class="link-btn"><%= p.status === 'active' ? '차단' : '해제' %></button>
            </form>
            <form action="/admin/products/<%= p.id %>/status" method="post" class="inline-form"
                  data-confirm="정말 삭제하시겠습니까?">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <input type="hidden" name="action" value="delete" />
              <button type="submit" class="link-btn danger">삭제</button>
            </form>
          </td>
        </tr>
      <% }); %>
    </tbody>
  </table>
</div>

<div id="reports"></div>
<div class="card">
  <h3>신고 내역 (<%= reports.length %>)</h3>
  <table class="table">
    <thead><tr><th>ID</th><th>신고자</th><th>유형</th><th>대상ID</th><th>사유</th><th>일시</th></tr></thead>
    <tbody>
      <% reports.forEach(function(r) { %>
        <tr>
          <td><%= r.id %></td>
          <td><%= r.reporter %></td>
          <td><%= r.target_type %></td>
          <td><%= r.target_id %></td>
          <td><%= r.reason %></td>
          <td><%= r.created_at %></td>
        </tr>
      <% }); %>
    </tbody>
  </table>
</div>

<div id="inquiries"></div>
<div class="card">
  <h3>사용자 문의 (<%= inquiries.length %>)</h3>
  <% if (inquiries.length === 0) { %>
    <p class="muted">접수된 문의가 없습니다.</p>
  <% } else { %>
    <% inquiries.forEach(function(q) { %>
      <div class="inquiry-item">
        <div class="inquiry-head">
          <strong><%= q.subject %></strong>
          <span class="muted">by <%= q.asker %> · <%= q.created_at %></span>
          <span class="badge badge-<%= q.status === 'answered' ? 'ok' : 'danger' %>">
            <%= q.status === 'answered' ? '답변완료' : '대기중' %>
          </span>
        </div>
        <p class="inquiry-body"><%= q.content %></p>
        <% if (q.status === 'answered') { %>
          <div class="inquiry-answer">
            <strong>[내 답변]</strong>
            <p><%= q.answer %></p>
            <p class="muted">답변일: <%= q.answered_at %></p>
          </div>
        <% } else { %>
          <form action="/admin/inquiries/<%= q.id %>/answer" method="post">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <textarea name="answer" rows="3" maxlength="2000" required placeholder="답변을 입력하세요"></textarea>
            <button type="submit" class="btn">답변 등록</button>
          </form>
        <% } %>
      </div>
    <% }); %>
  <% } %>
</div>

<div id="transfers"></div>
<div class="card">
  <h3>송금 내역 (<%= transfers.length %>)</h3>
  <% if (transfers.length === 0) { %>
    <p class="muted">송금/거래 내역이 없습니다.</p>
  <% } else { %>
    <table class="table">
      <thead><tr><th>ID</th><th>보내는이</th><th>받는이</th><th>금액</th><th>일시</th></tr></thead>
      <tbody>
        <% transfers.forEach(function(t) { %>
          <tr>
            <td><%= t.id %></td>
            <td><%= t.sender_name %></td>
            <td><%= t.receiver_name %></td>
            <td><%= t.amount.toLocaleString() %>원</td>
            <td><%= t.created_at %></td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  <% } %>
</div>

<div id="chat"></div>
<div class="card">
  <h3>전체 채팅 모니터링</h3>
  <p class="muted">전체(공개) 채팅을 실시간으로 확인하고 참여할 수 있습니다. 1:1 채팅은 열람할 수 없습니다.</p>
  <div class="chat-box">
    <ul id="messages" class="messages"></ul>
    <form id="chat-form" class="chat-form" autocomplete="off">
      <input id="chat-input" type="text" maxlength="500" placeholder="메시지를 입력하세요..." required />
      <button type="submit" class="btn">전송</button>
    </form>
  </div>
</div>

<script src="/socket.io/socket.io.js"></script>
<script src="/js/chat.js"></script>

<%- include('partials/footer') %>
