<%- include('partials/header') %>

<h2>관리자 문의</h2>

<div class="card">
  <h3>문의 작성</h3>
  <form action="/inquiry" method="post">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <label>제목
      <input type="text" name="subject" value="<%= (values && values.subject) || '' %>" required maxlength="100" />
    </label>
    <label>문의 내용
      <textarea name="content" rows="5" maxlength="2000" required placeholder="문의하실 내용을 작성하세요"><%= (values && values.content) || '' %></textarea>
    </label>
    <button type="submit" class="btn">문의 보내기</button>
  </form>
</div>

<div class="card">
  <h3>내 문의 내역</h3>
  <% if (inquiries.length === 0) { %>
    <p class="muted">보낸 문의가 없습니다.</p>
  <% } else { %>
    <% inquiries.forEach(function(q) { %>
      <div class="inquiry-item">
        <div class="inquiry-head">
          <strong><%= q.subject %></strong>
          <span class="badge badge-<%= q.status === 'answered' ? 'ok' : 'danger' %>">
            <%= q.status === 'answered' ? '답변완료' : '대기중' %>
          </span>
        </div>
        <p class="inquiry-body"><%= q.content %></p>
        <p class="muted">문의일: <%= q.created_at %></p>
        <% if (q.status === 'answered') { %>
          <div class="inquiry-answer">
            <strong>[관리자 답변]</strong>
            <p><%= q.answer %></p>
            <p class="muted">답변일: <%= q.answered_at %></p>
          </div>
        <% } %>
      </div>
    <% }); %>
  <% } %>
</div>

<%- include('partials/footer') %>
